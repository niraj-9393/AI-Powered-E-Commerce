{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2020"],
    "types": ["node"],

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true
  },
  "include": ["src/**/*"]
}